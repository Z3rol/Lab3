      "updated": 1776082730518,
      "link": null,
      "locked": false,
      "text": "Since arr has 2 rows, it has 1 even index (0),\nso 1 row should be added",
      "fontSize": 28,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Since arr has 2 rows, it has 1 even index (0),\nso 1 row should be added",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
