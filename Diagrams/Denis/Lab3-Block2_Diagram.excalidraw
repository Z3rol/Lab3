      "isDeleted": false,
      "boundElements": [],
      "updated": 1776082733102,
      "link": null,
      "locked": false,
      "text": "During the method it moves all rows\nthat go after even indexes to the next row,\nfilling it's previous position with empty array",
      "fontSize": 28,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "During the method it moves all rows\nthat go after even indexes to the next row,\nfilling it's previous position with empty array",
