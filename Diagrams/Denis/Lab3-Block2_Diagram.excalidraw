      "isDeleted": false,
      "boundElements": [],
      "updated": 1776082719701,
      "link": null,
      "locked": false,
      "text": "Call Array.Resize to add and empty row\nfor each even index (1) in our case",
      "fontSize": 28,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Call Array.Resize to add and empty row\nfor each even index (1) in our case",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
